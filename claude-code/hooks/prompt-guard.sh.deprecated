#!/bin/bash
# Claude Mainframe — UserPromptSubmit Hook v1.0
# Fires before each user prompt reaches Claude.
# Detects confidential topics and injects a privacy reminder.
#
# Output goes to stdout → gets injected into Claude's context alongside the prompt.

# Skip during ralph-loop — the loop re-submits the same prompt each iteration
# Check multiple possible marker locations for the ralph-loop plugin
if [ -f "$HOME/.claude/ralph-loop.local.md" ] || \
   [ -f "$HOME/.claude/plugins/ralph-loop/ralph-loop.local.md" ] || \
   [ -n "$RALPH_LOOP_ACTIVE" ]; then
    exit 0
fi

INPUT=""
if [ ! -t 0 ]; then
    INPUT=$(cat 2>/dev/null || true)
fi
[ -z "$INPUT" ] && exit 0

if ! command -v jq &>/dev/null; then
    exit 0
fi

# Extract the user's prompt text
PROMPT=$(echo "$INPUT" | jq -r '.prompt // empty' 2>/dev/null)
[ -z "$PROMPT" ] && exit 0

# Convert to lowercase for matching
PROMPT_LOWER=$(echo "$PROMPT" | tr '[:upper:]' '[:lower:]')

# Check for confidential signals
CONFIDENTIAL=false

# Relationship dynamics
if echo "$PROMPT_LOWER" | grep -qE '(dennis|dylan).*(condescend|frustrat|upset|angry|weird|unfair|power dynamic|hypocrit)'; then
    CONFIDENTIAL=true
fi

# Financial negotiations
if echo "$PROMPT_LOWER" | grep -qE '(equity split|compensation|revenue share|overpaid|underpaid|give.*(all|back).*revenue)'; then
    CONFIDENTIAL=true
fi

# Independence strategy
if echo "$PROMPT_LOWER" | grep -qE '(separate.*business|new llc|without dennis|on my own|dont tell|keep.*secret|between us)'; then
    CONFIDENTIAL=true
fi

# Explicit confidentiality markers
if echo "$PROMPT_LOWER" | grep -qE '(confidential|off the record|private|dont share|don.t share)'; then
    CONFIDENTIAL=true
fi

# Mentor/relationship assessment
if echo "$PROMPT_LOWER" | grep -qE '(bad mentor|good mentor|is dennis|do you think dennis|what do you think.*(dennis|dylan))'; then
    CONFIDENTIAL=true
fi

if [ "$CONFIDENTIAL" = true ]; then
    echo "[MAINFRAME CONFIDENTIALITY NOTICE: This conversation contains sensitive personal/strategic content. Do NOT extract relationship dynamics, personal assessments, or strategic positioning into SOPs, memory bank, or any shared files. Action items and process improvements may be extracted only if stripped of interpersonal context.]"
fi

exit 0
