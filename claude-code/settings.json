{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "Agent(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TodoWrite(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/pre-tool-guard.sh",
            "timeout": 5,
            "if": "Bash(*)|Write(*)|Edit(*)"
          },
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/enforce-naming.sh",
            "timeout": 5,
            "if": "Write(*)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/post-tool.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/post-tool-backup.sh",
            "timeout": 5,
            "if": "Write(*)|Edit(*)"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/task-completed.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/stop-summary.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/session-end.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/stop-failure.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash {{PRISM_PATH}}/claude-code/hooks/post-compact.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
